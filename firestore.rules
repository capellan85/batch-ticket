rules_version = '2';

// Batch Ticket security rules.
// Each signed-in user can read and write ONLY their own document at
// users/{uid}, which holds { recipes: [...] }. Everything else is denied.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
